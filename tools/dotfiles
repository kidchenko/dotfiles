#!/bin/bash
#
# dotfiles - CLI for managing dotfiles
#
# Usage:
#   dotfiles <command> [options]
#
# Commands:
#   update      Pull and apply latest changes
#   doctor      Run health checks
#   status      Show pending changes
#   packages    Manage packages (system, global, extensions)
#   ssh         Setup SSH keys
#   defaults    Apply macOS system defaults
#   cron        Manage scheduled tasks
#   logs        View logs
#   backup      Backup project folders
#   setup       Complete post-bootstrap setup
#   bootstrap   Bootstrap on new machine
#   destroy     Remove dotfiles and state
#   help        Show this help message
#

DOTFILES_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/chezmoi"
TOOLS_DIR="$DOTFILES_DIR/tools"

# Version
VERSION="1.0.0"

# Colors
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    DIM='\033[2m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' DIM='' BOLD='' NC=''
fi

say() { echo -e "${GREEN}[dotfiles]${NC} $1"; }
error() { echo -e "${RED}[dotfiles] ERROR:${NC} $1" >&2; exit 1; }

show_help() {
    echo -e "${BOLD}dotfiles${NC} v${VERSION} - CLI for managing dotfiles"
    echo ""
    echo -e "${BOLD}Usage:${NC}"
    echo "  dotfiles <command> [options]"
    echo ""
    echo -e "${BOLD}Daily:${NC}"
    echo -e "  ${CYAN}update${NC}                   Pull and apply latest changes"
    echo -e "  ${CYAN}doctor${NC}                   Run health checks"
    echo -e "      ${DIM}--quick${NC}              Skip slow checks (disk, outdated)"
    echo -e "      ${DIM}--fix${NC}                Auto-fix issues"
    echo -e "  ${CYAN}status${NC}                   Show pending changes"
    echo ""
    echo -e "${BOLD}Packages:${NC}"
    echo -e "  ${CYAN}packages${NC}                 Manage all packages"
    echo -e "      ${DIM}install${NC}              Install system packages (default)"
    echo -e "      ${DIM}cleanup${NC}              Remove unlisted packages"
    echo -e "      ${DIM}list${NC}                 Show installed packages"
    echo -e "      ${DIM}outdated${NC}             Show packages with updates"
    echo -e "      ${DIM}global${NC}               Install global tools (npm/pip/dotnet)"
    echo -e "      ${DIM}extensions${NC}           Install extensions (vscode|browser|all)"
    echo ""
    echo -e "${BOLD}System:${NC}"
    echo -e "  ${CYAN}ssh${NC}                      Setup SSH keys with 1Password"
    echo -e "      ${DIM}sync${NC}                 Auto-sync (used by setup)"
    echo -e "      ${DIM}restore${NC}              Restore key from 1Password to ~/.ssh/"
    echo -e "      ${DIM}generate${NC}             Generate new key in 1Password"
    echo -e "      ${DIM}show${NC}                 Show local public key"
    echo -e "      ${DIM}compare${NC}              Compare local key with 1Password"
    echo -e "  ${CYAN}defaults${NC}                 Apply macOS system defaults"
    echo -e "  ${CYAN}cron${NC}                     Manage scheduled tasks"
    echo -e "      ${DIM}list${NC}                 List scheduled tasks (default)"
    echo -e "      ${DIM}setup${NC}                Setup cron jobs"
    echo -e "  ${CYAN}logs${NC}                     View logs"
    echo -e "      ${DIM}backup${NC}               View backup logs"
    echo -e "      ${DIM}packages${NC}             View package install logs"
    echo -e "  ${CYAN}backup${NC}                   Backup project folders"
    echo -e "      ${DIM}list${NC}                 List available backups"
    echo -e "      ${DIM}restore${NC}              Restore from backup"
    echo ""
    echo -e "${BOLD}Lifecycle:${NC}"
    echo -e "  ${CYAN}setup${NC}                    Complete post-bootstrap setup"
    echo -e "  ${CYAN}bootstrap${NC}                Bootstrap on new machine"
    echo -e "  ${CYAN}destroy${NC}                  Remove dotfiles and state"
    echo -e "      ${DIM}--all${NC}                Also remove chezmoi state, zsh data"
    echo -e "      ${DIM}--deep${NC}               Factory reset: remove all dev tools"
    echo ""
    echo -e "${BOLD}Utility:${NC}"
    echo -e "  ${CYAN}help${NC}                     Show this help message"
    echo -e "  ${CYAN}--version${NC}                Show version"
    echo ""
}

cmd_doctor() {
    if [[ -f "$TOOLS_DIR/doctor.sh" ]]; then
        bash "$TOOLS_DIR/doctor.sh" "$@"
    else
        error "doctor.sh not found in $TOOLS_DIR"
    fi
}

cmd_bootstrap() {
    if [[ -f "$TOOLS_DIR/bootstrap.sh" ]]; then
        bash "$TOOLS_DIR/bootstrap.sh" "$@"
    else
        error "bootstrap.sh not found in $TOOLS_DIR"
    fi
}

cmd_destroy() {
    if [[ -f "$TOOLS_DIR/destroy.sh" ]]; then
        bash "$TOOLS_DIR/destroy.sh" "$@"
    else
        error "destroy.sh not found in $TOOLS_DIR"
    fi
}

cmd_update() {
    if [[ -f "$TOOLS_DIR/update.sh" ]]; then
        bash "$TOOLS_DIR/update.sh" "$@"
    else
        # Fallback to chezmoi update
        say "Updating dotfiles..."
        chezmoi update
    fi
}

cmd_status() {
    echo -e "${BOLD}Dotfiles Changes${NC}"
    echo ""

    # Show chezmoi diff (pending dotfile changes)
    local diff_output
    diff_output=$(chezmoi diff 2>/dev/null)
    if [[ -n "$diff_output" ]]; then
        echo -e "${YELLOW}Pending dotfile changes:${NC}"
        echo "$diff_output"
        echo ""
    else
        echo -e "${GREEN}No pending dotfile changes${NC}"
        echo ""
    fi

    # Show git status
    echo -e "${BOLD}Git Status${NC}"
    git -C "$DOTFILES_DIR" status --short "$@"
}

cmd_backup() {
    local backup_script="$TOOLS_DIR/backup-projects.sh"
    if [[ -f "$backup_script" ]]; then
        bash "$backup_script" "$@"
    else
        error "backup-projects.sh not found in $TOOLS_DIR"
    fi
}

cmd_packages() {
    local BREWFILE="$DOTFILES_DIR/Brewfile"

    case "${1:-install}" in
        install)
            shift 2>/dev/null || true
            if [[ "$(uname -s)" == "Darwin" ]] || command -v brew &>/dev/null; then
                if [[ ! -f "$BREWFILE" ]]; then
                    error "Brewfile not found at $BREWFILE"
                fi
                say "Installing packages from Brewfile..."
                brew bundle install --file="$BREWFILE" --verbose "$@"
                echo ""
                say "Done! Run 'dotfiles packages cleanup' to remove unlisted packages."
            elif [[ "$(uname -s)" == *"MINGW"* ]] || [[ "$(uname -s)" == *"MSYS"* ]] || command -v choco &>/dev/null; then
                local choco_script="$TOOLS_DIR/os_installers/choco.ps1"
                if [[ -f "$choco_script" ]]; then
                    say "Installing packages via Chocolatey..."
                    powershell -ExecutionPolicy Bypass -File "$choco_script"
                else
                    error "choco.ps1 not found at $choco_script"
                fi
            else
                error "No supported package manager found (brew or choco)"
            fi
            ;;
        cleanup)
            shift 2>/dev/null || true
            if [[ "$(uname -s)" == "Darwin" ]] || command -v brew &>/dev/null; then
                if [[ ! -f "$BREWFILE" ]]; then
                    error "Brewfile not found at $BREWFILE"
                fi
                say "Checking for unlisted packages..."
                brew bundle cleanup --file="$BREWFILE" "$@"
            else
                echo "Cleanup is only supported with Homebrew"
            fi
            ;;
        list)
            if command -v brew &>/dev/null; then
                echo -e "${BOLD}Installed Packages${NC}"
                echo ""
                echo -e "${CYAN}Formulae:${NC}"
                brew list --formula
                echo ""
                echo -e "${CYAN}Casks:${NC}"
                brew list --cask
            elif command -v choco &>/dev/null; then
                choco list --local-only
            else
                error "No supported package manager found"
            fi
            ;;
        outdated)
            if command -v brew &>/dev/null; then
                echo -e "${BOLD}Outdated Packages${NC}"
                echo ""
                local outdated
                outdated=$(brew outdated --verbose 2>/dev/null)
                if [[ -n "$outdated" ]]; then
                    echo "$outdated"
                    echo ""
                    echo -e "${DIM}Run 'brew upgrade' to update all packages${NC}"
                else
                    echo -e "${GREEN}All packages are up to date${NC}"
                fi
            elif command -v choco &>/dev/null; then
                choco outdated
            else
                error "No supported package manager found"
            fi
            ;;
        global)
            shift 2>/dev/null || true
            local global_script="$TOOLS_DIR/install-global-tools.sh"
            if [[ -f "$global_script" ]]; then
                bash "$global_script" "$@"
            else
                error "install-global-tools.sh not found in $TOOLS_DIR"
            fi
            ;;
        extensions)
            shift 2>/dev/null || true
            local vscode_script="$TOOLS_DIR/install-vscode-extensions.sh"
            local browser_script="$TOOLS_DIR/install-brave-extensions.sh"
            local ext_cmd="${1:-all}"
            case "$ext_cmd" in
                vscode|code)
                    if [[ -f "$vscode_script" ]]; then
                        bash "$vscode_script"
                    else
                        error "install-vscode-extensions.sh not found in $TOOLS_DIR"
                    fi
                    ;;
                browser|brave)
                    if [[ -f "$browser_script" ]]; then
                        bash "$browser_script"
                    else
                        error "install-brave-extensions.sh not found in $TOOLS_DIR"
                    fi
                    ;;
                all|"")
                    say "Installing all extensions..."
                    echo ""
                    say "VS Code extensions:"
                    if [[ -f "$vscode_script" ]]; then
                        bash "$vscode_script"
                    else
                        echo "  (skipped - script not found)"
                    fi
                    echo ""
                    say "Browser extensions:"
                    if [[ -f "$browser_script" ]]; then
                        bash "$browser_script"
                    else
                        echo "  (skipped - script not found)"
                    fi
                    ;;
                *)
                    echo "Usage: dotfiles packages extensions [vscode|browser|all]"
                    ;;
            esac
            ;;
        *)
            echo "Usage: dotfiles packages [install|cleanup|list|outdated|global|extensions]"
            echo ""
            echo "Commands:"
            echo "  install     Install system packages from Brewfile (default)"
            echo "  cleanup     Remove packages not in Brewfile"
            echo "  list        Show installed packages"
            echo "  outdated    Show packages with available updates"
            echo "  global      Install global tools (npm/pip/dotnet)"
            echo "  extensions  Install extensions (vscode|browser|all)"
            ;;
    esac
}

cmd_logs() {
    local LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"

    case "${1:-list}" in
        backup)
            if [[ -f "$LOG_DIR/backup.log" ]]; then
                less +G "$LOG_DIR/backup.log"
            elif [[ -f "$LOG_DIR/backup-cron.log" ]]; then
                less +G "$LOG_DIR/backup-cron.log"
            else
                echo "No backup logs found in $LOG_DIR"
            fi
            ;;
        packages|brew|bundle)
            if [[ -f "$LOG_DIR/brew-bundle.log" ]]; then
                less +G "$LOG_DIR/brew-bundle.log"
            else
                echo "No package install logs found in $LOG_DIR"
            fi
            ;;
        list|*)
            echo -e "${BOLD}Available Logs${NC}"
            echo ""
            if [[ -d "$LOG_DIR" ]]; then
                for log in "$LOG_DIR"/*.log; do
                    [[ -f "$log" ]] || continue
                    local name
                    local size
                    local modified
                    name=$(basename "$log" .log)
                    size=$(du -h "$log" | cut -f1)
                    modified=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$log" 2>/dev/null)
                    echo -e "  ${GREEN}$name${NC} ($size) - $modified"
                done
                echo ""
                echo "View a log: dotfiles logs <name>"
            else
                echo "  No logs directory found"
            fi
            ;;
    esac
}

cmd_cron() {
    local CRON_DIR="$DOTFILES_DIR/cron"
    local CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/config.yaml"

    case "${1:-list}" in
        list)
            echo -e "${BOLD}Scheduled Tasks${NC}"
            echo ""

            # Check if yq is available
            if ! command -v yq &>/dev/null; then
                echo -e "  ${YELLOW}yq not installed - cannot read config${NC}"
                echo "  Install with: brew install yq"
                return 1
            fi

            if [[ ! -f "$CONFIG_FILE" ]]; then
                echo -e "  ${YELLOW}Config file not found${NC}"
                echo "  Run: chezmoi apply"
                return 1
            fi

            # Read jobs from config.yaml and check if installed
            local job_count
            job_count=$(yq -r '.cron.jobs | length' "$CONFIG_FILE" 2>/dev/null)

            if [[ -z "$job_count" || "$job_count" == "0" || "$job_count" == "null" ]]; then
                echo -e "  ${YELLOW}No cron jobs defined in config.yaml${NC}"
                return 0
            fi

            local crontab_content
            crontab_content=$(crontab -l 2>/dev/null || echo "")

            for ((i=0; i<job_count; i++)); do
                local script description
                script=$(yq -r ".cron.jobs[$i].script" "$CONFIG_FILE")
                description=$(yq -r ".cron.jobs[$i].description" "$CONFIG_FILE")

                if echo "$crontab_content" | grep -q "$script"; then
                    echo -e "  ${GREEN}✓${NC} $description"
                else
                    echo -e "  ${YELLOW}○${NC} $description ${DIM}(not installed)${NC}"
                fi
            done

            echo ""
            echo -e "${DIM}Run 'dotfiles cron setup' to install/update jobs${NC}"
            echo ""
            ;;
        setup)
            if [[ -f "$TOOLS_DIR/setup-cron.sh" ]]; then
                bash "$TOOLS_DIR/setup-cron.sh"
            else
                error "setup-cron.sh not found in $TOOLS_DIR"
            fi
            ;;
        *)
            echo "Usage: dotfiles cron [list|setup]"
            echo ""
            echo "Commands:"
            echo "  list   Show configured cron jobs (default)"
            echo "  setup  Install/update all cron jobs"
            ;;
    esac
}

cmd_defaults() {
    local defaults_script="$TOOLS_DIR/os_setup/macos-config.sh"

    if [[ ! "$(uname -s)" == "Darwin" ]]; then
        error "This command is only available on macOS"
    fi

    if [[ -f "$defaults_script" ]]; then
        say "Applying macOS defaults..."
        bash "$defaults_script" "$@"
    else
        error "macos-config.sh not found in $TOOLS_DIR/os_setup"
    fi
}

cmd_ssh() {
    local ssh_script="$TOOLS_DIR/setup-ssh-keys.sh"

    if [[ -f "$ssh_script" ]]; then
        bash "$ssh_script" "$@"
    else
        error "setup-ssh-keys.sh not found in $TOOLS_DIR"
    fi
}

cmd_setup() {
    say "Running complete setup..."
    echo ""

    # Ask for sudo password upfront
    say "Some steps require administrator privileges."
    sudo -v

    # Keep sudo alive in background for the duration of setup
    (while true; do sudo -n true; sleep 50; kill -0 "$$" 2>/dev/null || exit; done) &
    local sudo_keeper_pid=$!
    trap "kill $sudo_keeper_pid 2>/dev/null" EXIT

    echo ""

    say "Step 1/6: Setting up SSH keys..."
    cmd_ssh sync
    echo ""

    say "Step 2/6: Installing system packages..."
    cmd_packages install
    echo ""

    say "Step 3/6: Installing global tools & extensions..."
    cmd_packages global
    cmd_packages extensions
    echo ""

    say "Step 4/6: Setting up cron jobs..."
    cmd_cron setup
    echo ""

    say "Step 5/6: Applying system defaults..."
    if [[ "$(uname -s)" == "Darwin" ]]; then
        cmd_defaults
    else
        echo "  (skipped - macOS only)"
    fi
    echo ""

    # Stop the sudo keeper
    kill $sudo_keeper_pid 2>/dev/null

    say "Setup complete!"
    say "Run 'dotfiles doctor' to verify everything is configured correctly."
}

# Main
case "${1:-help}" in
    update)
        shift
        cmd_update "$@"
        ;;
    doctor)
        shift
        cmd_doctor "$@"
        ;;
    status)
        shift
        cmd_status "$@"
        ;;
    packages)
        shift
        cmd_packages "$@"
        ;;
    ssh)
        shift
        cmd_ssh "$@"
        ;;
    defaults)
        shift
        cmd_defaults "$@"
        ;;
    cron)
        shift
        cmd_cron "$@"
        ;;
    logs)
        shift
        cmd_logs "$@"
        ;;
    backup)
        shift
        cmd_backup "$@"
        ;;
    setup)
        shift
        cmd_setup "$@"
        ;;
    bootstrap)
        shift
        cmd_bootstrap "$@"
        ;;
    destroy)
        shift
        cmd_destroy "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    --version|-v)
        echo "dotfiles v${VERSION}"
        ;;
    *)
        error "Unknown command: $1\nRun 'dotfiles help' for usage."
        ;;
esac
