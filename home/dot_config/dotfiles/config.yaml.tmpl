# Dotfiles Configuration
# Located at ~/.config/dotfiles/config.yaml after chezmoi applies it.
#
# Sections:
#   - global_tools: npm/pip/dotnet packages to install globally
#   - cron: Scheduled task definitions
#   - backup: Backup folders, excludes, and settings
#   - extensions: VS Code and browser extensions
#   - ssh: 1Password SSH key settings

global_tools:
  npm:
    - typescript          # TypeScript compiler
    - prettier            # Code formatter
    - npm-check-updates   # Check for outdated dependencies (ncu)

  pip:
    - httpie              # Better curl for API testing
    - pipx                # Install Python CLI tools in isolation

  dotnet:
    - dotnet-ef             # Entity Framework Core tools
    - dotnet-outdated-tool  # Check for outdated NuGet packages

# Cron jobs configuration
# Each job has: script name, cron schedule, and description
cron:
  jobs:
    # Security & Updates
    - script: update.sh
      schedule: "0 9 * * 1"
      description: Weekly brew bundle (Monday 9am)

    - script: outdated.sh
      schedule: "0 8 * * *"
      description: Daily outdated packages check (8am)

    - script: cleanup.sh
      schedule: "0 10 * * 0"
      description: Weekly cleanup - brew & caches (Sunday 10am)

    # Backups & Maintenance
    - script: backup.sh
      schedule: "0 2 * * 0"
      description: Weekly backup (Sunday 2am)

    - script: git-maintenance.sh
      schedule: "0 4 * * 6"
      description: Weekly git maintenance (Saturday 4am)

    # Health Monitoring
    - script: health.sh
      schedule: "0 7 * * *"
      description: Daily health check (7am)

# Backup configuration
backup:
  # Folders to backup (relative to $HOME or absolute paths)
  folders:
    - kidchenko
    - lambda3
    - jetabroad
    - thoughtworks
    - sevenpeaks
    - isho
    - Documents
    - Downloads
    - dotnetthailand

  # Patterns to exclude from backup
  exclude:
    - node_modules
    - .git
    - vendor
    - .venv
    - __pycache__
    - .pytest_cache
    - .mypy_cache
    - .tox
    - dist
    - build
    - "*.pyc"
    - ".DS_Store"
    - Thumbs.db
    - .idea
    - .vs
    - bin
    - obj
    - packages
    - .nuget
    - .npm
    - .yarn
    - .pnpm-store

  # Local backup settings
  local:
    base_dir: ~/Backups
    retention_days: 7

  # Remote backup settings (rclone)
  remote:
    enabled: true
    rclone_remote: GoogleDrive
    rclone_path: DotfilesBackups/

  # Logging
  logging:
    enabled: true
    dir: ~/.local/log
    retention_days: 30

# Extensions configuration
extensions:
  vscode:
    # General
    - EditorConfig.EditorConfig
    - dbaeumer.vscode-eslint
    - esbenp.prettier-vscode
    - eamodio.gitlens
    - usernamehw.errorlens
    - Gruntfuggly.todo-tree
    - streetsidesoftware.code-spell-checker
    - oderwat.indent-rainbow
    # Remote Development
    - ms-vscode-remote.remote-containers
    - ms-vscode-remote.remote-ssh
    - ms-azuretools.vscode-docker
    # Languages
    - ms-python.python
    - ms-python.vscode-pylance
    - redhat.vscode-yaml
    # Web
    - ms-vscode.live-server
    - formulahendry.auto-rename-tag
    - formulahendry.auto-close-tag

  brave:
    - aeblfdkhhhdcdjpifhhbdiojplfjncoa  # 1Password
    - kbfnbcaeplbcioakkpcpgfkobkghlhen  # Grammarly
    - bdakmnplckeopfghnlpocafcepegjeap  # RescueTime

# SSH key configuration (1Password)
ssh:
  vault: development
  item_name: "SSH Key"
  key_type: ed25519
